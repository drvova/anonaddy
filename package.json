{
    "private": true,
    "packageManager": "npm@11.6.0",
    "engines": {
        "node": ">=22.0.0 <23",
        "npm": ">=11.6.0 <12"
    },
    "scripts": {
        "dev": "vite --host",
        "production": "vite build",
        "format": "prettier --write 'resources/**/*.{css,ts,tsx}'",
        "prepare": "husky",
        "pre-commit": "lint-staged"
    },
    "dependencies": {
        "@inertiajs/core": "^3.0.0",
        "@kobalte/core": "^0.13.11",
        "@kobalte/tailwindcss": "^0.9.0",
        "@solid-primitives/deep": "^0.3.0",
        "@solid-primitives/memo": "^1.4.5",
        "@solidjs/meta": "^0.29.4",
        "@tailwindcss/forms": "^0.5.3",
        "@thisbeyond/solid-dnd": "^0.7.5",
        "autoprefixer": "^10.4.1",
        "chart.js": "^4.5.1",
        "cross-env": "^10.0.0",
        "dayjs": "^1.10.4",
        "es-toolkit": "^1.30.0",
        "mini-svg-data-uri": "^1.4.4",
        "postcss": "^8.4.5",
        "postcss-import": "^16.0.0",
        "resolve-url-loader": "^5.0.0",
        "solid-js": "^1.9.0",
        "tailwindcss": "^3.0.11"
    },
    "devDependencies": {
        "husky": "^9.0.0",
        "laravel-vite-plugin": "^3.0.0",
        "lint-staged": "^16.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.7.0",
        "vite": "^8.0.0",
        "vite-plugin-solid": "^2.11.0"
    },
    "overrides": {
        "vite": {
            "rollup": "npm:@rollup/wasm-node"
        }
    },
    "lint-staged": {
        "*.{css,ts,tsx}": [
            "prettier --write"
        ],
        "*.php": [
            "composer format"
        ]
    }
}
